rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================
    // HELPER FUNCTIONS
    // =====================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isNotBanned() {
      return isAuthenticated() &&
        (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("status", "ACTIVE") != "BANNED");
    }

    // Helper for device check (used directly in match blocks for better control)
    function isDeviceNotBanned(deviceId) {
      return deviceId == null || 
             !exists(/databases/$(database)/documents/devices/$(deviceId)) || 
             get(/databases/$(database)/documents/devices/$(deviceId)).data.get("status", "ACTIVE") != "BANNED";
    }

    // =====================================
    // USERS
    // =====================================

    match /users/{userId} {

      // Admin can read all users
      allow read: if isAdmin();

      // Admin can create users/admins
      allow create: if isAdmin();

      // Admin can update ONLY role/status
      allow update: if isAdmin() &&
        request.resource.data.name == resource.data.name &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.phone == resource.data.phone &&
        request.resource.data.createdAt == resource.data.createdAt;

      // No direct delete
      allow delete: if false;

      // =====================================
      // USER SELF ACCESS
      // =====================================

      // User signup
      allow create: if
        request.auth.uid == userId;

      // User read own profile
      allow read: if
        request.auth.uid == userId;

      // User update own profile
      allow update: if
        request.auth.uid == userId &&
        isNotBanned();
    }

    // =====================================
    // DEVICES
    // =====================================

    match /devices/{deviceId} {
      // Allow a device to read its own info to check its status (even if banned)
      allow read: if isAuthenticated();
      
      // Allow write only if user is NOT banned (device status check handled inside isNotBanned if desired, 
      // but here we allow registration/update if user is okay)
      allow write: if isAuthenticated() && isNotBanned();

      // Admin full access
      allow read, write: if isAdmin();

      // No delete
      allow delete: if false;
    }

    // =====================================
    // TICKETS
    // =====================================

    match /tickets/{ticketId} {
      // Admin full access
      allow read, write: if isAdmin();

      // User create own ticket
      allow create: if
        isAuthenticated() &&
        isNotBanned() &&
        isDeviceNotBanned(request.resource.data.get('deviceId', null)) &&
        request.resource.data.userId == request.auth.uid;

      // User read own tickets
      allow read: if
        isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        isNotBanned() &&
        isDeviceNotBanned(resource.data.get('deviceId', null));

      // No update/delete
      allow update, delete: if false;
    }

    // =====================================
    // NOTIFICATIONS
    // =====================================

    match /notifications/{notificationId} {

      // Users read only
      allow read: if
        isAuthenticated() &&
        isNotBanned();

      // Admin manage
      allow write: if isAdmin();
    }

    // =====================================
    // ROUTES
    // =====================================

    match /routes/{routeId} {

      // Users can read
      allow read: if
        isAuthenticated() &&
        isNotBanned();

      // Admin manage
      allow write: if isAdmin();
    }

    // =====================================
    // STOPS
    // =====================================

    match /stops/{stopId} {

      // Users can read
      allow read: if
        isAuthenticated() &&
        isNotBanned();

      // Admin manage
      allow write: if isAdmin();
    }

    // =====================================
    // LOGS
    // =====================================

    match /logs/{logId} {
      // App create logs
      allow write: if isAuthenticated();

      // Admin only
      allow read, update, delete: if isAdmin();
    }

    // =====================================
    // METADATA
    // =====================================

    match /metadata/{documentId} {

      // Users can read
      allow read: if
        isAuthenticated() &&
        isNotBanned();

      // Admin manage
      allow write: if isAdmin(); 
    }
  }
}
