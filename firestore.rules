rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================
    // HELPER FUNCTIONS
    // =====================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "admin@onedelhi.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "").upper() == "ADMIN"))
      );
    }

    function isNotBanned() {
      return isAuthenticated() &&
        (isAdmin() || 
         !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("status", "ACTIVE") != "BANNED");
    }

    // Helper for device check (used directly in match blocks for better control)
    function isDeviceNotBanned(deviceId) {
      return isAdmin() ||
             deviceId == null || 
             !exists(/databases/$(database)/documents/devices/$(deviceId)) || 
             get(/databases/$(database)/documents/devices/$(deviceId)).data.get("status", "ACTIVE") != "BANNED";
    }

    // =====================================
    // USERS
    // =====================================

    match /users/{userId} {

      // Admin can read all users
      allow read: if isAdmin();

      // Admin can create users/admins
      allow create: if isAdmin();

      // Admin can update users/admins
      allow update: if isAdmin();

      // Admin delete access
      allow delete: if isAdmin();

      // =====================================
      // USER SELF ACCESS
      // =====================================

      // User signup
      allow create: if
        request.auth.uid == userId;

      // User read own profile
      allow read: if
        request.auth.uid == userId;

      // User update own profile
      allow update: if
        request.auth.uid == userId &&
        isNotBanned();
    }

    // =====================================
    // DEVICES
    // =====================================

    match /devices/{deviceId} {
      // Allow a device to read its own info to check its status (even if banned)
      allow read: if isAuthenticated();
      
      // Allow write only if user is NOT banned (device status check handled inside isNotBanned if desired, 
      // but here we allow registration/update if user is okay)
      allow write: if isAuthenticated() && isNotBanned();

      // Admin full access
      allow read, write: if isAdmin();

      // No delete
      allow delete: if false;
    }

    // =====================================
    // TICKETS
    // =====================================

    match /tickets/{ticketId} {
      // Admin full access
      allow read, write: if isAdmin();

      // User create own ticket
      allow create: if
        isAuthenticated() &&
        isNotBanned() &&
        isDeviceNotBanned(request.resource.data.get('deviceId', null)) &&
        request.resource.data.userId == request.auth.uid;

      // User read own tickets
      allow read: if
        isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        isNotBanned() &&
        isDeviceNotBanned(resource.data.get('deviceId', null));

      // No update/delete
      allow update, delete: if false;
    }

    // =====================================
    // NOTIFICATIONS
    // =====================================

    match /notifications/{notificationId} {
      // Users can read broadcast
      allow read: if isAuthenticated() && (isAdmin() || isNotBanned());
      // Admin manage
      allow write: if isAdmin();
    }

    // =====================================
    // ROUTES
    // =====================================

    match /routes/{routeId} {
      allow read: if isAuthenticated() && (isAdmin() || isNotBanned());
      allow write: if isAdmin();
    }

    // =====================================
    // STOPS
    // =====================================

    match /stops/{stopId} {
      allow read: if isAuthenticated() && (isAdmin() || isNotBanned());
      allow write: if isAdmin();
    }

    // =====================================
    // LOGS
    // =====================================

    match /logs/{logId} {
      allow read, write: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /deleted_users/{docId} {
      allow read, write: if isAdmin();
    }

    // =====================================
    // METADATA
    // =====================================

    match /metadata/{documentId} {
      allow read: if isAuthenticated() && (isAdmin() || isNotBanned());
      allow write: if isAdmin();
    }
  }
}
